{
  "info": {
    "name": "Quarkus CRUD - OpenShift",
    "_postman_id": "quarkus-crud-openshift-collection",
    "description": "Colección de pruebas para los endpoints /hello, /productos y middleware del proyecto Quarkus CRUD desplegado en OpenShift.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "description": "Cambia este valor por la Route pública generada por OpenShift"
    }
  ],
  "item": [
    {
      "name": "Favoritos",
      "item": [
        {
          "name": "POST /favoritos - Crear",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Respuesta contiene id', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.id).to.be.a('number');",
                  "    pm.collectionVariables.set('favoritoId', json.id);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipo\": \"CENTRO\",\n  \"referenciaId\": \"SUC-001\",\n  \"descripcion\": \"Sucursal Central\"\n}"
            },
            "url": "{{baseUrl}}/favoritos"
          }
        },
        {
          "name": "POST /favoritos - 409 Conflict (duplicado)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409 Conflict', function () {",
                  "    pm.response.to.have.status(409);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tipo\": \"CENTRO\",\n  \"referenciaId\": \"SUC-001\",\n  \"descripcion\": \"Sucursal Central\"\n}"
            },
            "url": "{{baseUrl}}/favoritos"
          }
        },
        {
          "name": "GET /favoritos - Listar todos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Respuesta es un array', function () {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/favoritos"
          }
        },
        {
          "name": "DELETE /favoritos/:id - Eliminar",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204 No Content', function () {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/favoritos/{{favoritoId}}"
          }
        },
        {
          "name": "DELETE /favoritos/:id - 404 Not Found",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 Not Found', function () {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/favoritos/99999"
          }
        }
      ]
    },
    {
      "name": "Hello",
      "item": [
        {
          "name": "GET /hello",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/hello"
          }
        }
      ]
    },
    {
      "name": "Productos - CRUD",
      "item": [
        {
          "name": "GET /productos - Listar todos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/productos"
          }
        },
        {
          "name": "GET /productos/:id - Buscar por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/productos/1"
          }
        },
        {
          "name": "POST /productos - Crear",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Laptop\",\n  \"precio\": 999.99,\n  \"stock\": 10\n}"
            },
            "url": "{{baseUrl}}/productos"
          }
        },
        {
          "name": "PUT /productos/:id - Actualizar",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Laptop Pro\",\n  \"precio\": 1299.99,\n  \"stock\": 5\n}"
            },
            "url": "{{baseUrl}}/productos/1"
          }
        },
        {
          "name": "DELETE /productos/:id - Eliminar",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/productos/1"
          }
        }
      ]
    },
    {
      "name": "Middleware Interfisa",
      "item": [
        {
          "name": "GET /api/sucursales - Centros de Servicio",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/api/sucursales",
            "description": "Consulta pública de centros de servicio (Microcentro) vía Middleware Interfisa."
          }
        },
        {
          "name": "GET /api/sipap - Parámetros SIPAP",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": "{{baseUrl}}/api/sipap",
            "description": "Consulta segura de motivos SIPAP usando JWT inyectado desde ConfigMap."
          }
        }
      ]
    }
  ]
}
